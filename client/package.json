{
  "name": "client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run watch:openapi\" \"vite\"",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "tsc --noEmit",
    "build": "tsc -b && vite build --base=/dist",
    "watch:openapi": "nodemon",
    "codegen": "rimraf src/api/* && orval --config orval.config.ts",
    "lint:check": "eslint .",
    "lint": "eslint . --fix",
    "fmt:check": "prettier . --check",
    "fmt": "prettier . --write",
    "preview": "vite preview",
    "e2e": "npx playwright test",
    "e2e:dev": "npx playwright test --ui",
    "e2e:report": "npx playwright show-report"
  },
  "dependencies": {
    "@fontsource-variable/merriweather": "5.2.6",
    "@fontsource-variable/public-sans": "5.2.7",
    "@headlessui/react": "2.2.10",
    "@tailwindcss/vite": "4.3.0",
    "@tanstack/react-query": "5.100.14",
    "@tanstack/react-virtual": "^3.13.26",
    "@trussworks/react-uswds": "11.0.1",
    "axios": "1.16.1",
    "classnames": "2.5.1",
    "fuse.js": "7.3.0",
    "react": "19.2.7",
    "react-diff-viewer-continued": "4.2.2",
    "react-dom": "19.2.7",
    "react-markdown": "10.1.0",
    "react-router": "7.15.1",
    "react-spinners": "0.17.0",
    "react-toastify": "11.1.0",
    "tailwindcss": "4.3.0",
    "use-debounce": "10.1.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@emnapi/core": "1.10.0",
    "@emnapi/runtime": "1.10.0",
    "@eslint/js": "9.39.4",
    "@playwright/test": "1.60.0",
    "@tanstack/eslint-plugin-query": "5.100.14",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.12.2",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/parser": "8.59.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.6",
    "concurrently": "10.0.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "eslint-plugin-testing-library": "7.16.2",
    "focus-trap-react": "11.0.6",
    "globals": "17.6.0",
    "jsdom": "29.1.1",
    "jsdom-testing-mocks": "1.16.0",
    "nodemon": "3.1.14",
    "orval": "8.10.0",
    "pg": "8.20.0",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.8.0",
    "rimraf": "6.1.3",
    "sass-embedded": "1.99.0",
    "typescript": "5.9.3",
