---
pagination:
  data: pythonApiArray.modules
  size: 1
  alias: module
permalink: "/reference/python-api/module-{{ module.name | replace: '.', '-' }}/"
layout: layout.liquid
---

<h1 class="font-merriweather text-3xl font-bold mb-2">{{ module.name }}</h1>

{% if module.docstring %}
<div class="prose max-w-none mb-6">
  {{ module.docstring | renderMarkdown | sanitize }}
</div>
{% endif %}

{% if module.members and module.members.size > 0 %}
<h2 class="font-merriweather text-xl font-semibold mb-4">Members</h2>
<div class="space-y-6">
  {% for member in module.members %}
  <div id="{{ member.name }}" class="border rounded-lg p-6 border-gray-cool-4 scroll-mt-4 max-w-3xl">
    <h3 class="text-lg font-semibold mb-2 group">
      <span class="text-gray-60 text-sm">{{ member.type }}</span>
      <code class="ml-2">{{ member.name }}</code>
      <a href="#{{ member.name }}" class="ml-2 text-gray-40 hover:text-gray-60 opacity-0 group-hover:opacity-100 transition-opacity" aria-label="Link to {{ member.name }}">#</a>
    </h3>
    {% assign has_parsed = false %}
    {% if member.parsed_docstring.summary != "" or member.parsed_docstring.description != "" %}
      {% assign has_parsed = true %}
    {% endif %}
    {% if has_parsed %}
      <div class="prose max-w-none mt-6 text-xl">
        {{ member.parsed_docstring | renderDocstring | renderMarkdown | sanitize }}
      </div>
    {% elsif member.docstring %}
      <div class="prose max-w-none mb-3">
        {{ member.docstring | renderMarkdown | sanitize }}
      </div>
    {% endif %}
    {% if member.signature %}
    <div class="bg-gray-2 rounded p-3 font-mono text-sm mb-3">
      {{ member.signature }}
    </div>
    {% endif %}
    {% if member.parameters and member.parameters.size > 0 %}
    <h4 class="text-sm font-medium text-gray-60 mb-2 mt-3">Parameters (raw)</h4>
    <table class="text-sm">
      <thead>
        <tr class="border-b border-gray-cool-4">
          <th class="text-left py-1 pr-4">Name</th>
          <th class="text-left py-1 pr-4">Type</th>
          <th class="text-left py-1">Default</th>
        </tr>
      </thead>
      <tbody>
        {% for param in member.parameters %}
        <tr class="border-b border-gray-cool-3">
          <td class="py-1 pr-4 font-mono text-sm">{{ param.name }}</td>
          <td class="py-1 pr-4 font-mono text-sm text-gray-60">{{ param.annotation }}</td>
          <td class="py-1 font-mono text-sm text-gray-60">{{ param.default }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    {% endif %}
    {% if member.return_annotation %}
    <div class="text-sm text-gray-60 mt-2">
      Returns: <code>{{ member.return_annotation }}</code>
    </div>
    {% endif %}
    {% if member.methods and member.methods.size > 0 %}
    <h4 class="text-sm font-medium text-gray-60 mt-4 mb-2">Methods</h4>
    <div class="space-y-3">
      {% for method in member.methods %}
      <div id="{{ member.name }}.{{ method.name }}" class="border-l-2 border-gray-cool-4 pl-4 scroll-mt-4 group">
        <div class="font-mono text-sm">
          <span class="text-gray-60">{{ method.name }}</span>
          <a href="#{{ member.name }}.{{ method.name }}" class="ml-2 text-gray-40 hover:text-gray-60 opacity-0 group-hover:opacity-100 transition-opacity text-xs" aria-label="Link to {{ member.name }}.{{ method.name }}">#</a>
        </div>
        {% assign has_method_parsed = false %}
        {% if method.parsed_docstring.summary != "" or method.parsed_docstring.description != "" %}
          {% assign has_method_parsed = true %}
        {% endif %}
        {% if has_method_parsed %}
          {{ method.parsed_docstring | renderDocstring }}
        {% elsif method.docstring %}
          <div class="text-sm text-gray-60 mt-1 prose max-w-none">
            {{ method.docstring | renderMarkdown | sanitize }}
          </div>
        {% endif %}
        {% if method.signature %}
        <div class="bg-gray-2 rounded p-2 font-mono text-xs mt-1">
          {{ method.signature }}
        </div>
        {% endif %}
      </div>
      {% endfor %}
    </div>
    {% endif %}
  </div>
  {% endfor %}
</div>
{% endif %}
