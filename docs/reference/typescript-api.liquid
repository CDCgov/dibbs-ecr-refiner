---
layout: layout.liquid
title: TypeScript API Reference
pagination:
  data: typescriptApiArray.modules
  size: 1
  alias: item
permalink: "/reference/typescript-api/{{ item.slug }}/"
---

{% assign pageTitle = "TypeScript API Reference" %}

{%- comment -%} Prefer canonical module entry from typescriptApiArray in case the paginated item is partial. {%- endcomment -%}
{% assign me = typescriptApiArray.modules | where: "slug", item.slug | first %}
{% if me %}{% assign item = me %}{% endif %}

<h1>{{ pageTitle }}: <code>{{ item.name }}</code></h1>

<h2>Description</h2>
{% if item.docstring %}
  {% capture renderedDescription %}{% renderTemplate "liquid,md", item %}{{ docstring }}{% endrenderTemplate %}{% endcapture %}
  <div class="prose max-w-none">{{ renderedDescription | sanitize }}</div>
{% else %}
  <div class="prose max-w-none">No description provided.</div>
{% endif %}

<h2>Members</h2>
{% if item.members and item.members.size > 0 %}
<table class="w-full border-collapse mb-4 text-left" aria-describedby="module-members">
  <thead class="bg-gray-100 border-b border-gray-200 text-[0.9rem]">
    <tr><th class="px-3 py-2">Name</th><th class="px-3 py-2">Type</th><th class="px-3 py-2">Description</th></tr>
  </thead>
  <tbody class="text-[0.9rem]">
  {% for member in item.members %}
    <tr class="border-b border-gray-50">
      <td class="px-3 py-2"><code class="bg-gray-100 px-1.5 py-0.5 rounded text-sm">{{ member.name }}</code></td>
      <td class="px-3 py-2">{{ member.type }}</td>
      <td class="px-3 py-2">
        {% if member.description %}
          {% capture renderedMemberDescription %}{% renderTemplate "liquid,md", member %}{{ description }}{% endrenderTemplate %}{% endcapture %}
          <div class="prose max-w-none">{{ renderedMemberDescription | sanitize }}</div>
        {% else %}
          <p>No description provided.</p>
        {% endif %}
        {% if member.signatures and member.signatures.size > 0 %}
          <details open>
            <summary>Signatures</summary>
            <ul>
            {% for signature in member.signatures %}
              <li><code>{{ signature.name }}</code>{% if signature.docstring %}: {% capture renderedSignatureDescription %}{% renderTemplate "liquid,md", signature %}{{ docstring }}{% endrenderTemplate %}{% endcapture %} <span class="prose max-w-none">{{ renderedSignatureDescription | sanitize }}</span>{% endif %}</li>
            {% endfor %}
            </ul>
          </details>
        {% endif %}
      </td>
    </tr>
  {% endfor %}
  </tbody>
</table>
{% else %}
<p>No members.</p>
{% endif %}

<nav class="pagination">
  {%- comment -%} build prev/next slugs from typescriptApiArray.modules so links stay stable {%- endcomment -%}
  {% assign prevSlug = "" %}
  {% assign nextSlug = "" %}
  {% for module in typescriptApiArray.modules %}
    {% if module.slug == item.slug %}
      {% assign idx = forloop.index0 %}
      {% if idx > 0 %}
        {% assign prevIndex = idx | minus: 1 %}
        {% assign prevSlug = typescriptApiArray.modules[prevIndex].slug %}
      {% endif %}
      {% assign lastIndex = typescriptApiArray.modules | size | minus: 1 %}
      {% if idx < lastIndex %}
        {% assign nextIndex = idx | plus: 1 %}
        {% assign nextSlug = typescriptApiArray.modules[nextIndex].slug %}
      {% endif %}
      {% break %}
    {% endif %}
  {% endfor %}

  <div class="flex flex-col md:flex-row gap-4 mt-4">
    {% if prevSlug != "" %}
      {% assign prevModule = typescriptApiArray.modules | where: "slug", prevSlug | first %}
      <div class="w-full md:w-1/2">
        <a class="flex flex-col justify-center w-full h-[11vh] px-4 py-3 bg-gray-100 border border-gray-200 rounded-lg no-underline text-gray-900 items-start text-left" href="/reference/typescript-api/{{ prevSlug }}/" rel="prev" title="{{ prevModule.name }}">
          <div class="font-bold">&larr; Previous</div>
          <div class="text-sm">Members: {{ prevModule.memberCount }}</div>
          <div class="text-xs text-gray-600 truncate" title="{{ prevModule.name }}">{{ prevModule.name }}</div>
        </a>
      </div>
    {% endif %}

    {% if nextSlug != "" %}
      {% assign nextModule = typescriptApiArray.modules | where: "slug", nextSlug | first %}
      <div class="w-full md:w-1/2">
        <a class="flex flex-col justify-center w-full h-[11vh] px-4 py-3 bg-gray-100 border border-gray-200 rounded-lg no-underline text-gray-900 items-end text-right" href="/reference/typescript-api/{{ nextSlug }}/" rel="next" title="{{ nextModule.name }}">
          <div class="font-bold">Next &rarr;</div>
          <div class="text-sm">Members: {{ nextModule.memberCount }}</div>
          <div class="text-xs text-gray-600 truncate" title="{{ nextModule.name }}">{{ nextModule.name }}</div>
        </a>
      </div>
    {% endif %}
  </div>
</nav>
